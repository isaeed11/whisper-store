<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — إدارة الرسائل</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--radius:14px;}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;}
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;}
.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border);}
.sidebar-logo span{display:block;font-size:0.65rem;font-weight:400;color:var(--dim);}
.sidebar-nav{flex:1;padding:16px 12px;}
.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:0.9rem;font-weight:500;transition:0.3s;margin-bottom:4px;}
.sidebar-nav a:hover{background:var(--elevated);color:var(--text);}
.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700;}
.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center;}
.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border);}
.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:0.85rem;}
.main{margin-right:260px;flex:1;padding:32px;}
.page-header{margin-bottom:32px;}
.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800;}
.msg-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:16px;transition:0.3s;}
.msg-card:hover{border-color:rgba(200,169,126,0.3);}
.msg-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px;}
.msg-sender{font-weight:700;font-size:1rem;}
.msg-date{color:var(--muted);font-size:0.8rem;}
.msg-meta{display:flex;gap:20px;margin-bottom:12px;flex-wrap:wrap;}
.msg-meta div{font-size:0.85rem;color:var(--dim);}
.msg-meta div strong{color:var(--text);font-weight:600;}
.msg-subject{font-weight:600;color:var(--accent);font-size:0.9rem;margin-bottom:8px;}
.msg-body{color:var(--dim);font-size:0.95rem;line-height:1.8;padding:16px;background:var(--elevated);border-radius:10px;margin-bottom:16px;}
.btn-sm{padding:8px 18px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:0.8rem;font-weight:600;border:none;cursor:pointer;transition:0.3s;}
.btn-danger{background:rgba(199,80,80,0.15);color:var(--danger);border:1px solid rgba(199,80,80,0.3);}
.btn-danger:hover{background:rgba(199,80,80,0.25);}
@media(max-width:768px){.sidebar{display:none;}.main{margin-right:0;}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header"><h1>✉️ الرسائل (<%= messages.length %>)</h1></div>

  <% messages.forEach(m => { %>
  <div class="msg-card">
    <div class="msg-head">
      <span class="msg-sender"><%= m.name %></span>
      <span class="msg-date"><%= new Date(m.createdAt).toLocaleDateString('ar-SA') %> — <%= new Date(m.createdAt).toLocaleTimeString('ar-SA', {hour:'2-digit',minute:'2-digit'}) %></span>
    </div>
    <div class="msg-meta">
      <div>📧 <strong><%= m.email %></strong></div>
      <% if(m.phone) { %><div>📱 <strong style="direction:ltr;"><%= m.phone %></strong></div><% } %>
    </div>
    <% if(m.subject) { %><div class="msg-subject">📌 <%= m.subject %></div><% } %>
    <div class="msg-body"><%= m.message %></div>
    <form method="POST" action="/admin/messages/<%= m._id %>/delete" onsubmit="return confirm('متأكد من حذف الرسالة؟')">
      <button type="submit" class="btn-sm btn-danger">🗑️ حذف</button>
    </form>
  </div>
  <% }) %>

  <% if(messages.length === 0) { %>
    <div style="text-align:center;padding:60px;color:var(--dim);"><p style="font-size:3rem;margin-bottom:16px;">✉️</p><p>لا توجد رسائل بعد</p></div>
  <% } %>
</div>
</body>
</html>
