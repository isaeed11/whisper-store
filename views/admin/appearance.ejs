<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — تخصيص الواجهة</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.3/Sortable.min.js"></script>
<style>
.section-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px;margin-bottom:24px}
.section-card h3{font-family:'Noto Kufi Arabic',serif;font-size:1.1rem;font-weight:700;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.link-row{display:flex;gap:10px;align-items:center;padding:12px 14px;background:var(--elevated);border-radius:10px;margin-bottom:8px;transition:background .2s}
.link-row.sortable-ghost{opacity:0.4;background:var(--accent-glow)}
.link-row.sortable-chosen{background:rgba(200,169,126,0.1)}
.link-row .drag-handle{cursor:grab;color:var(--muted);font-size:1.2rem;flex-shrink:0;padding:0 4px}
.link-row .drag-handle:active{cursor:grabbing}
.link-row input{flex:1;padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-family:'Tajawal',sans-serif;font-size:.85rem;min-width:100px}
.link-row select{padding:8px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-family:'Tajawal',sans-serif;font-size:.85rem;min-width:130px}
.toggle{position:relative;width:36px;height:20px;flex-shrink:0}
.toggle input{opacity:0;width:100%;height:100%;position:absolute;cursor:pointer;z-index:1;margin:0}
.toggle-track{width:36px;height:20px;background:var(--muted);border-radius:10px;transition:.3s;position:absolute;top:0}
.toggle input:checked+.toggle-track{background:var(--accent)}
.toggle-track::after{content:'';position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:2px;right:2px;transition:.3s}
.toggle input:checked+.toggle-track::after{right:18px}
.btn-del{background:none;border:1px solid rgba(199,80,80,0.3);color:var(--danger);cursor:pointer;font-size:.8rem;padding:6px 10px;border-radius:6px;transition:.3s;flex-shrink:0;font-family:'Tajawal',sans-serif}
.btn-del:hover{background:rgba(199,80,80,0.15)}
.btn{padding:10px 24px;border-radius:60px;font-family:'Tajawal',sans-serif;font-size:.9rem;font-weight:600;border:none;cursor:pointer;transition:.3s;display:inline-flex;align-items:center;gap:6px;text-decoration:none}
.btn-accent{background:var(--accent);color:var(--bg)}.btn-accent:hover{background:#e0c9a6}
.btn-sm{padding:6px 16px;font-size:.8rem;border-radius:6px}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}.btn-outline:hover{border-color:var(--accent)}
.btn-block{width:100%;justify-content:center;text-align:center}
.section-item{display:flex;gap:12px;align-items:center;padding:14px 16px;background:var(--elevated);border-radius:10px;margin-bottom:8px;transition:background .2s}
.section-item.sortable-ghost{opacity:0.4;background:var(--accent-glow)}
.section-item .drag-handle{cursor:grab;color:var(--muted);font-size:1.2rem}
.section-item .name{flex:1;font-weight:600;font-size:.95rem}
.form-group{margin-bottom:16px}.form-group label{display:block;font-size:.85rem;font-weight:600;color:var(--dim);margin-bottom:6px}
.form-group input{width:100%;padding:12px;border-radius:8px;border:1px solid var(--border);background:var(--elevated);color:var(--text);font-family:'Tajawal',sans-serif;font-size:.9rem;outline:none}
.checkbox-label{display:flex;align-items:center;gap:8px;font-size:.9rem;cursor:pointer;margin-bottom:8px}
.saved-msg{background:rgba(109,181,109,.15);border:1px solid rgba(109,181,109,.3);color:var(--success);padding:12px 20px;border-radius:10px;margin-bottom:24px}
.hint{font-size:.75rem;color:var(--muted);margin-top:8px}
@media(max-width:768px){.link-row{flex-wrap:wrap}.link-row input,.link-row select{min-width:100%}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header"><h1>🎨 تخصيص الواجهة</h1><p>تحكم بالهيدر والفوتر وترتيب أقسام الصفحة الرئيسية — اسحب لترتيب</p></div>

  <% if (saved) { %><div class="saved-msg">✅ تم حفظ التعديلات!</div><% } %>

  <form method="POST" action="/admin/appearance" id="mainForm">

    <!-- ═══ النافبار ═══ -->
    <div class="section-card">
      <h3>🔝 روابط النافبار (الهيدر)</h3>
      <div id="navContainer">
        <% settings.navLinks.sort((a,b) => a.order - b.order).forEach((link, i) => { %>
        <div class="link-row" data-type="nav" data-idx="<%= i %>">
          <span class="drag-handle">⋮⋮</span>
          <input class="lnk-label" value="<%= link.label %>" placeholder="اسم الرابط">
          <select class="lnk-page">
            <option value="home" <%= link.page==='home'?'selected':'' %>>الرئيسية</option>
            <option value="products" <%= link.page==='products'?'selected':'' %>>المعدات</option>
            <option value="reviews" <%= link.page==='reviews'?'selected':'' %>>التقييمات</option>
            <option value="contact" <%= link.page==='contact'?'selected':'' %>>تواصل معنا</option>
            <option value="external" <%= link.page==='external'?'selected':'' %>>رابط خارجي</option>
            <% pages.forEach(p => { %><option value="page-<%= p.slug %>" <%= link.page==='page-'+p.slug?'selected':'' %>>📄 <%= p.title %></option><% }) %>
          </select>
          <input class="lnk-url" value="<%= link.url||'' %>" placeholder="رابط خارجي" style="direction:ltr;text-align:right;min-width:150px;">
          <div class="toggle"><input type="checkbox" class="lnk-visible" <%= link.visible?'checked':'' %>><div class="toggle-track"></div></div>
          <button type="button" class="btn-del" onclick="this.closest('.link-row').remove()">حذف</button>
        </div>
        <% }) %>
      </div>
      <button type="button" class="btn btn-sm btn-outline" style="margin-top:12px;" onclick="addLink('nav')">+ إضافة رابط</button>
      <div class="hint">اسحب ⋮⋮ لتغيير الترتيب — اضغط حذف لإزالة الرابط</div>
    </div>

    <!-- ═══ الفوتر ═══ -->
    <div class="section-card">
      <h3>📎 تخصيص الفوتر</h3>
      <div class="form-group"><label>وصف الفوتر (اختياري)</label><input name="footerDescription" value="<%= settings.footerDescription||'' %>" placeholder="نص يظهر تحت الشعار"></div>
      <label class="checkbox-label"><input type="checkbox" name="showSocialInFooter" <%= settings.showSocialInFooter!==false?'checked':'' %>> إظهار روابط السوشال ميديا</label>

      <h4 style="font-size:.95rem;font-weight:700;margin:20px 0 12px;">روابط الفوتر</h4>
      <div id="footerContainer">
        <% settings.footerLinks.sort((a,b) => a.order - b.order).forEach((link, i) => { %>
        <div class="link-row" data-type="footer" data-idx="<%= i %>">
          <span class="drag-handle">⋮⋮</span>
          <input class="lnk-label" value="<%= link.label %>" placeholder="اسم الرابط">
          <select class="lnk-page">
            <option value="home" <%= link.page==='home'?'selected':'' %>>الرئيسية</option>
            <option value="products" <%= link.page==='products'?'selected':'' %>>المعدات</option>
            <option value="reviews" <%= link.page==='reviews'?'selected':'' %>>التقييمات</option>
            <option value="contact" <%= link.page==='contact'?'selected':'' %>>تواصل معنا</option>
            <option value="external" <%= link.page==='external'?'selected':'' %>>رابط خارجي</option>
            <% pages.forEach(p => { %><option value="page-<%= p.slug %>" <%= link.page==='page-'+p.slug?'selected':'' %>>📄 <%= p.title %></option><% }) %>
          </select>
          <input class="lnk-url" value="<%= link.url||'' %>" placeholder="رابط خارجي" style="direction:ltr;text-align:right;min-width:150px;">
          <div class="toggle"><input type="checkbox" class="lnk-visible" <%= link.visible?'checked':'' %>><div class="toggle-track"></div></div>
          <button type="button" class="btn-del" onclick="this.closest('.link-row').remove()">حذف</button>
        </div>
        <% }) %>
      </div>
      <button type="button" class="btn btn-sm btn-outline" style="margin-top:12px;" onclick="addLink('footer')">+ إضافة رابط</button>
      <div class="hint">اسحب ⋮⋮ لتغيير الترتيب — اضغط حذف لإزالة الرابط</div>
    </div>

    <!-- ═══ أقسام الرئيسية ═══ -->
    <div class="section-card">
      <h3>📐 ترتيب أقسام الصفحة الرئيسية</h3>
      <p style="color:var(--dim);font-size:.85rem;margin-bottom:16px;">اسحب لتغيير الترتيب — أطفئ التوقل لإخفاء القسم</p>
      <div id="sectionsContainer">
        <% settings.homeSections.sort((a,b) => a.order - b.order).forEach((sec, i) => { %>
        <div class="section-item" data-id="<%= sec.id %>" data-label="<%= sec.label %>">
          <span class="drag-handle">⋮⋮</span>
          <span class="name"><%= sec.label %></span>
          <div class="toggle"><input type="checkbox" class="sec-visible" <%= sec.visible?'checked':'' %>><div class="toggle-track"></div></div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Hidden inputs populated by JS before submit -->
    <div id="hiddenInputs"></div>

    <button type="submit" class="btn btn-accent btn-block" style="max-width:400px;margin:0 auto;display:block;">💾 حفظ تخصيص الواجهة</button>
  </form>
</div>

<script>
// ═══ Drag & Drop with SortableJS ═══
const navSortable = new Sortable(document.getElementById('navContainer'), {
  handle: '.drag-handle', animation: 200, ghostClass: 'sortable-ghost', chosenClass: 'sortable-chosen'
});
const footerSortable = new Sortable(document.getElementById('footerContainer'), {
  handle: '.drag-handle', animation: 200, ghostClass: 'sortable-ghost', chosenClass: 'sortable-chosen'
});
const sectionsSortable = new Sortable(document.getElementById('sectionsContainer'), {
  handle: '.drag-handle', animation: 200, ghostClass: 'sortable-ghost', chosenClass: 'sortable-chosen'
});

// ═══ Add Link ═══
const pageOptions = `<option value="home">الرئيسية</option><option value="products">المعدات</option><option value="reviews">التقييمات</option><option value="contact">تواصل معنا</option><option value="external">رابط خارجي</option><% pages.forEach(p => { %><option value="page-<%= p.slug %>">📄 <%= p.title %></option><% }) %>`;

function addLink(type) {
  const container = document.getElementById(type === 'nav' ? 'navContainer' : 'footerContainer');
  const div = document.createElement('div');
  div.className = 'link-row';
  div.dataset.type = type;
  div.innerHTML = `<span class="drag-handle">⋮⋮</span><input class="lnk-label" placeholder="اسم الرابط"><select class="lnk-page">${pageOptions}</select><input class="lnk-url" placeholder="رابط خارجي" style="direction:ltr;text-align:right;min-width:150px;"><div class="toggle"><input type="checkbox" class="lnk-visible" checked><div class="toggle-track"></div></div><button type="button" class="btn-del" onclick="this.closest('.link-row').remove()">حذف</button>`;
  container.appendChild(div);
}

// ═══ Before Submit: collect all data into hidden inputs ═══
document.getElementById('mainForm').addEventListener('submit', function(e) {
  const hidden = document.getElementById('hiddenInputs');
  hidden.innerHTML = '';

  function addHidden(name, value) {
    const inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = name; inp.value = value;
    hidden.appendChild(inp);
  }

  // Nav links
  document.querySelectorAll('#navContainer .link-row').forEach((row, i) => {
    addHidden(`nav_label_${i}`, row.querySelector('.lnk-label').value);
    addHidden(`nav_page_${i}`, row.querySelector('.lnk-page').value);
    addHidden(`nav_url_${i}`, row.querySelector('.lnk-url').value);
    addHidden(`nav_visible_${i}`, row.querySelector('.lnk-visible').checked ? 'on' : '');
  });
  addHidden('navLinksCount', document.querySelectorAll('#navContainer .link-row').length);

  // Footer links
  document.querySelectorAll('#footerContainer .link-row').forEach((row, i) => {
    addHidden(`footer_label_${i}`, row.querySelector('.lnk-label').value);
    addHidden(`footer_page_${i}`, row.querySelector('.lnk-page').value);
    addHidden(`footer_url_${i}`, row.querySelector('.lnk-url').value);
    addHidden(`footer_visible_${i}`, row.querySelector('.lnk-visible').checked ? 'on' : '');
  });
  addHidden('footerLinksCount', document.querySelectorAll('#footerContainer .link-row').length);

  // Sections
  document.querySelectorAll('#sectionsContainer .section-item').forEach((item, i) => {
    addHidden(`section_id_${i}`, item.dataset.id);
    addHidden(`section_label_${i}`, item.dataset.label);
    addHidden(`section_order_${i}`, i);
    addHidden(`section_visible_${i}`, item.querySelector('.sec-visible').checked ? 'on' : '');
  });
  addHidden('sectionsCount', document.querySelectorAll('#sectionsContainer .section-item').length);
});
</script>
</body></html>
