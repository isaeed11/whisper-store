<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — إدارة الأعضاء</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--radius:14px}
*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;z-index:10}.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border)}.sidebar-logo span{display:block;font-size:.65rem;font-weight:400;color:var(--dim)}.sidebar-nav{flex:1;padding:16px 12px}.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:.9rem;font-weight:500;transition:.3s;margin-bottom:4px}.sidebar-nav a:hover{background:var(--elevated);color:var(--text)}.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700}.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center}.sidebar-nav a .badge-nav{margin-right:auto;background:var(--danger);color:#fff;font-size:.65rem;padding:2px 8px;border-radius:10px;font-weight:700}.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border)}.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:.85rem}
.main{margin-right:260px;flex:1;padding:32px}.page-header{margin-bottom:32px}.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800}
.table-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}table{width:100%;border-collapse:collapse}th{text-align:right;padding:14px 24px;font-size:.8rem;color:var(--dim);font-weight:600;border-bottom:1px solid var(--border)}td{padding:14px 24px;font-size:.9rem;border-bottom:1px solid var(--border)}tr:hover td{background:var(--elevated)}
.stat-mini{display:inline-block;padding:3px 10px;border-radius:12px;font-size:.75rem;font-weight:700}.stat-orders{background:rgba(100,160,255,0.15);color:#64a0ff}.stat-spent{background:var(--accent-glow);color:var(--accent)}
@media(max-width:768px){.sidebar{display:none}.main{margin-right:0}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header"><h1>👥 الأعضاء المسجلين (<%= customers.length %>)</h1></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>الاسم</th><th>الجوال</th><th>الإيميل</th><th>الطلبات</th><th>إجمالي الإنفاق</th><th>تاريخ التسجيل</th></tr></thead>
      <tbody>
        <% customers.forEach(c => { %>
        <tr>
          <td style="font-weight:700"><%= c.name || 'بدون اسم' %></td>
          <td style="direction:ltr;text-align:right;"><%= c.phone %></td>
          <td><%= c.email || '—' %></td>
          <td><span class="stat-mini stat-orders"><%= c.orderCount %> طلب</span></td>
          <td><span class="stat-mini stat-spent"><%= c.totalSpent %> ر.س</span></td>
          <td style="color:var(--dim);font-size:.85rem"><%= new Date(c.createdAt).toLocaleDateString('ar-SA') %></td>
        </tr>
        <% }) %>
        <% if(customers.length===0) { %><tr><td colspan="6" style="text-align:center;padding:40px;color:var(--dim)">لا يوجد أعضاء مسجلين بعد</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
</body></html>
