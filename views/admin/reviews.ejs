<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — إدارة التقييمات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--radius:14px;}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;}
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;}
.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border);}
.sidebar-logo span{display:block;font-size:0.65rem;font-weight:400;color:var(--dim);}
.sidebar-nav{flex:1;padding:16px 12px;}
.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:0.9rem;font-weight:500;transition:0.3s;margin-bottom:4px;}
.sidebar-nav a:hover{background:var(--elevated);color:var(--text);}
.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700;}
.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center;}
.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border);}
.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:0.85rem;}
.main{margin-right:260px;flex:1;padding:32px;}
.page-header{margin-bottom:32px;}
.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800;}
.review-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:16px;display:flex;justify-content:space-between;align-items:flex-start;gap:20px;transition:0.3s;flex-wrap:wrap;}
.review-card:hover{border-color:rgba(200,169,126,0.3);}
.review-main{flex:1;min-width:200px;}
.review-stars{color:var(--accent);font-size:0.9rem;letter-spacing:2px;margin-bottom:8px;}
.review-text{color:var(--dim);font-size:0.95rem;margin-bottom:12px;font-style:italic;}
.review-author{font-weight:700;font-size:0.9rem;}
.review-date{color:var(--muted);font-size:0.8rem;}
.review-actions{display:flex;gap:8px;align-items:center;flex-shrink:0;}
.btn-sm{padding:8px 18px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:0.8rem;font-weight:600;border:none;cursor:pointer;transition:0.3s;}
.btn-accent{background:var(--accent);color:var(--bg);}
.btn-success{background:rgba(109,181,109,0.15);color:var(--success);border:1px solid rgba(109,181,109,0.3);}
.btn-danger{background:rgba(199,80,80,0.15);color:var(--danger);border:1px solid rgba(199,80,80,0.3);}
.badge{padding:3px 10px;border-radius:12px;font-size:0.7rem;font-weight:700;}
.badge-ok{background:rgba(109,181,109,0.15);color:var(--success);}
.badge-hidden{background:rgba(199,80,80,0.15);color:var(--danger);}
@media(max-width:768px){.sidebar{display:none;}.main{margin-right:0;}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header"><h1>⭐ إدارة التقييمات (<%= reviews.length %>)</h1></div>

  <% reviews.forEach(r => { %>
  <div class="review-card">
    <div class="review-main">
      <div class="review-stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5-r.rating) %></div>
      <div class="review-text">"<%= r.text %>"</div>
      <div style="display:flex;align-items:center;gap:12px;">
        <span class="review-author"><%= r.name %></span>
        <span class="badge <%= r.approved ? 'badge-ok' : 'badge-hidden' %>"><%= r.approved ? 'ظاهر' : 'مخفي' %></span>
        <span class="review-date"><%= new Date(r.createdAt).toLocaleDateString('ar-SA') %></span>
      </div>
    </div>
    <div class="review-actions">
      <form method="POST" action="/admin/reviews/<%= r._id %>/toggle" style="display:inline;">
        <button type="submit" class="btn-sm <%= r.approved ? 'btn-danger' : 'btn-success' %>"><%= r.approved ? 'إخفاء' : 'إظهار' %></button>
      </form>
      <form method="POST" action="/admin/reviews/<%= r._id %>/delete" style="display:inline;" onsubmit="return confirm('متأكد من الحذف؟')">
        <button type="submit" class="btn-sm btn-danger">حذف</button>
      </form>
    </div>
  </div>
  <% }) %>

  <% if(reviews.length === 0) { %>
    <div style="text-align:center;padding:60px;color:var(--dim);"><p style="font-size:3rem;margin-bottom:16px;">⭐</p><p>لا توجد تقييمات بعد</p></div>
  <% } %>
</div>
</body>
</html>
