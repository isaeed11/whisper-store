<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — تسجيل الدخول</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<style>
:root { --bg:#0a0a0a; --card:#111; --accent:#c8a97e; --accent-glow:rgba(200,169,126,0.15); --text:#f0ece4; --dim:#8a8578; --border:rgba(200,169,126,0.12); --radius:14px; }
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.login-box{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:48px 40px;width:100%;max-width:420px;text-align:center;}
.logo{font-family:'Noto Kufi Arabic',serif;font-size:2rem;font-weight:900;color:var(--accent);letter-spacing:4px;text-transform:uppercase;margin-bottom:8px;}
.logo span{display:block;font-size:0.7rem;font-weight:400;color:var(--dim);letter-spacing:2px;}
.subtitle{color:var(--dim);font-size:0.9rem;margin:16px 0 32px;}
.form-group{margin-bottom:20px;text-align:right;}
.form-group label{display:block;font-size:0.85rem;font-weight:600;color:var(--dim);margin-bottom:8px;}
.form-group input{width:100%;padding:14px 16px;border-radius:8px;border:1px solid var(--border);background:#1a1a1a;color:var(--text);font-family:'Tajawal',sans-serif;font-size:0.95rem;outline:none;transition:0.3s;}
.form-group input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow);}
.btn{width:100%;padding:14px;border-radius:60px;background:var(--accent);color:var(--bg);font-family:'Tajawal',sans-serif;font-size:1rem;font-weight:700;border:none;cursor:pointer;transition:0.3s;margin-top:8px;}
.btn:hover{background:#e0c9a6;transform:translateY(-2px);box-shadow:0 8px 30px rgba(200,169,126,0.3);}
.error{background:rgba(199,80,80,0.15);border:1px solid rgba(199,80,80,0.3);color:#e87070;padding:12px;border-radius:8px;font-size:0.85rem;margin-bottom:20px;}
.back{display:inline-block;margin-top:24px;color:var(--dim);text-decoration:none;font-size:0.85rem;transition:0.3s;}
.back:hover{color:var(--accent);}
</style>
</head>
<body>
<div class="login-box">
  <div class="logo">WHISPER<span>لوحة التحكم</span></div>
  <p class="subtitle">سجّل دخولك لإدارة المتجر</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form method="POST" action="/admin/login">
    <div class="form-group">
      <label>البريد الإلكتروني</label>
      <input type="email" name="email" placeholder="admin@whisper-rental.com" required style="direction:ltr;text-align:right;">
    </div>
    <div class="form-group">
      <label>كلمة المرور</label>
      <input type="password" name="password" placeholder="••••••••" required>
    </div>
    <button type="submit" class="btn">تسجيل الدخول ←</button>
  </form>
  <a href="/" class="back">← العودة للمتجر</a>
</div>
</body>
</html>
