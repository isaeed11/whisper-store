<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — إدارة الكوبونات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--radius:14px}
*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;z-index:10}.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border)}.sidebar-logo span{display:block;font-size:.65rem;font-weight:400;color:var(--dim)}.sidebar-nav{flex:1;padding:16px 12px}.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:.9rem;font-weight:500;transition:.3s;margin-bottom:4px}.sidebar-nav a:hover{background:var(--elevated);color:var(--text)}.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700}.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center}.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border)}.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:.85rem}
.main{margin-right:260px;flex:1;padding:32px}.page-header{margin-bottom:32px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800}
.btn{padding:10px 24px;border-radius:60px;font-family:'Tajawal',sans-serif;font-size:.9rem;font-weight:600;border:none;cursor:pointer;transition:.3s;display:inline-flex;align-items:center;gap:6px;text-decoration:none}.btn-accent{background:var(--accent);color:var(--bg)}.btn-accent:hover{background:#e0c9a6}.btn-danger{background:rgba(199,80,80,.15);color:var(--danger);border:1px solid rgba(199,80,80,.3)}.btn-sm{padding:6px 16px;font-size:.8rem;border-radius:6px}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px}.modal-bg.show{display:flex}.modal{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);width:100%;max-width:540px;max-height:90vh;overflow-y:auto;padding:32px}.modal h3{font-family:'Noto Kufi Arabic',serif;font-size:1.2rem;font-weight:700;margin-bottom:24px}
.form-group{margin-bottom:16px}.form-group label{display:block;font-size:.85rem;font-weight:600;color:var(--dim);margin-bottom:6px}.form-group input,.form-group select,.form-group textarea{width:100%;padding:12px;border-radius:8px;border:1px solid var(--border);background:var(--elevated);color:var(--text);font-family:'Tajawal',sans-serif;font-size:.9rem;outline:none}.form-group input:focus,.form-group select:focus{border-color:var(--accent)}.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.hint{font-size:.75rem;color:var(--muted);margin-top:4px}
.coupon-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:16px;transition:.3s}.coupon-card:hover{border-color:rgba(200,169,126,.3)}
.coupon-code{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:4px;direction:ltr;display:inline-block;background:var(--accent-glow);padding:6px 16px;border-radius:8px;margin-bottom:12px}
.coupon-meta{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:12px}.coupon-meta span{font-size:.85rem;color:var(--dim)}.coupon-meta strong{color:var(--text)}
.badge{padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700}.badge-ok{background:rgba(109,181,109,.15);color:var(--success)}.badge-no{background:rgba(199,80,80,.15);color:var(--danger)}.badge-type{background:var(--accent-glow);color:var(--accent)}
.coupon-actions{display:flex;gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}
.empty{text-align:center;padding:60px;color:var(--dim)}
@media(max-width:768px){.sidebar{display:none}.main{margin-right:0}.form-row{grid-template-columns:1fr}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header">
    <h1>🏷️ إدارة الكوبونات (<%= coupons.length %>)</h1>
    <button class="btn btn-accent" onclick="document.getElementById('addModal').classList.add('show')">+ كوبون جديد</button>
  </div>

  <% coupons.forEach(c => { %>
  <div class="coupon-card">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px;">
      <div class="coupon-code"><%= c.code %></div>
      <div>
        <span class="badge <%= c.active ? 'badge-ok' : 'badge-no' %>"><%= c.active ? 'مفعّل' : 'معطّل' %></span>
        <span class="badge badge-type"><%= c.type === 'percentage' ? c.value + '%' : c.value + ' ر.س' %></span>
      </div>
    </div>
    <% if (c.description) { %><p style="color:var(--dim);font-size:.9rem;margin-bottom:12px;"><%= c.description %></p><% } %>
    <div class="coupon-meta">
      <span>الاستخدام: <strong><%= c.usedCount %><%= c.usageLimit > 0 ? '/' + c.usageLimit : '' %></strong></span>
      <span>لكل مستخدم: <strong><%= c.perUserLimit %> مرة</strong></span>
      <% if (c.minOrderAmount > 0) { %><span>حد أدنى: <strong><%= c.minOrderAmount %> ر.س</strong></span><% } %>
      <% if (c.maxDiscount > 0) { %><span>حد خصم: <strong><%= c.maxDiscount %> ر.س</strong></span><% } %>
      <% if (c.expiryDate) { %><span>ينتهي: <strong><%= new Date(c.expiryDate).toLocaleDateString('ar-SA') %></strong></span><% } %>
    </div>
    <div class="coupon-actions">
      <form method="POST" action="/admin/coupons/<%= c._id %>/toggle" style="display:inline;"><button type="submit" class="btn btn-sm <%= c.active ? 'btn-danger' : 'btn-accent' %>"><%= c.active ? 'تعطيل' : 'تفعيل' %></button></form>
      <form method="POST" action="/admin/coupons/<%= c._id %>/delete" style="display:inline;" onsubmit="return confirm('متأكد؟')"><button type="submit" class="btn btn-sm btn-danger">حذف</button></form>
    </div>
  </div>
  <% }) %>

  <% if (!coupons.length) { %><div class="empty"><p style="font-size:3rem;margin-bottom:16px;">🏷️</p><p>لا توجد كوبونات — أنشئ أول كوبون!</p></div><% } %>
</div>

<div class="modal-bg" id="addModal" onclick="if(event.target===this)this.classList.remove('show')">
  <div class="modal">
    <h3>➕ إنشاء كوبون جديد</h3>
    <form method="POST" action="/admin/coupons">
      <div class="form-row">
        <div class="form-group"><label>كود الكوبون</label><input name="code" required placeholder="مثال: WELCOME20" style="text-transform:uppercase;direction:ltr;text-align:right;font-weight:700;letter-spacing:2px;"></div>
        <div class="form-group"><label>نوع الخصم</label><select name="type" required><option value="percentage">نسبة مئوية (%)</option><option value="fixed">مبلغ ثابت (ر.س)</option></select></div>
      </div>
      <div class="form-group"><label>قيمة الخصم</label><input type="number" name="value" required min="1" placeholder="مثال: 20"><div class="hint">لو نسبة: 20 = خصم 20% | لو مبلغ ثابت: 50 = خصم 50 ر.س</div></div>
      <div class="form-group"><label>وصف (اختياري)</label><input name="description" placeholder="مثال: خصم بمناسبة الافتتاح"></div>
      <div class="form-row">
        <div class="form-group"><label>الحد الأدنى للطلب (ر.س)</label><input type="number" name="minOrderAmount" value="0" min="0"><div class="hint">0 = بدون حد أدنى</div></div>
        <div class="form-group"><label>حد الخصم الأقصى (ر.س)</label><input type="number" name="maxDiscount" value="0" min="0"><div class="hint">0 = بدون حد | مفيد للنسبة المئوية</div></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>حد الاستخدام الكلي</label><input type="number" name="usageLimit" value="0" min="0"><div class="hint">0 = بلا حدود</div></div>
        <div class="form-group"><label>حد لكل مستخدم</label><input type="number" name="perUserLimit" value="1" min="1"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>تاريخ البداية (اختياري)</label><input type="date" name="startDate"></div>
        <div class="form-group"><label>تاريخ الانتهاء (اختياري)</label><input type="date" name="expiryDate"></div>
      </div>
      <button type="submit" class="btn btn-accent" style="width:100%;justify-content:center;margin-top:8px;">إنشاء الكوبون</button>
    </form>
  </div>
</div>
</body></html>
