<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — لوحة التحكم</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--warning:#d4a843;--radius:14px;}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;}

/* Sidebar */
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;z-index:100;}
.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border);}
.sidebar-logo span{display:block;font-size:0.65rem;font-weight:400;color:var(--dim);letter-spacing:1px;margin-top:-2px;}
.sidebar-nav{flex:1;padding:16px 12px;}
.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:0.9rem;font-weight:500;transition:0.3s;margin-bottom:4px;}
.sidebar-nav a:hover{background:var(--elevated);color:var(--text);}
.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700;}
.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center;}
.sidebar-nav a .badge-nav{margin-right:auto;background:var(--danger);color:#fff;font-size:0.65rem;padding:2px 8px;border-radius:10px;font-weight:700;}
.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border);}
.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:0.85rem;transition:0.3s;}
.sidebar-bottom a:hover{color:var(--danger);}

/* Main Content */
.main{margin-right:260px;flex:1;padding:32px;min-height:100vh;}
.page-header{margin-bottom:32px;}
.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800;}
.page-header p{color:var(--dim);font-size:0.9rem;margin-top:4px;}

/* Stats Grid */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:32px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;transition:0.3s;}
.stat-card:hover{border-color:rgba(200,169,126,0.3);transform:translateY(-2px);}
.stat-card .icon{font-size:2rem;margin-bottom:12px;}
.stat-card .value{font-family:'Noto Kufi Arabic',serif;font-size:2rem;font-weight:900;color:var(--accent);}
.stat-card .label{color:var(--dim);font-size:0.85rem;margin-top:4px;}

/* Table */
.table-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.table-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.table-header h3{font-family:'Noto Kufi Arabic',serif;font-size:1.1rem;font-weight:700;}
table{width:100%;border-collapse:collapse;}
th{text-align:right;padding:14px 24px;font-size:0.8rem;color:var(--dim);font-weight:600;text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border);}
td{padding:14px 24px;font-size:0.9rem;border-bottom:1px solid var(--border);}
tr:hover td{background:var(--elevated);}
.status-badge{padding:4px 14px;border-radius:20px;font-size:0.75rem;font-weight:700;}
.status-pending{background:rgba(212,168,67,0.15);color:var(--warning);}
.status-confirmed{background:rgba(109,181,109,0.15);color:var(--success);}
.status-active{background:rgba(100,160,255,0.15);color:#64a0ff;}
.status-returned{background:rgba(200,169,126,0.15);color:var(--accent);}
.status-cancelled{background:rgba(199,80,80,0.15);color:var(--danger);}
.btn-sm{padding:6px 16px;border-radius:6px;font-size:0.8rem;font-family:'Tajawal',sans-serif;font-weight:600;border:none;cursor:pointer;transition:0.3s;}
.btn-accent{background:var(--accent);color:var(--bg);}
.btn-accent:hover{background:#e0c9a6;}

@media(max-width:768px){
  .sidebar{display:none;}
  .main{margin-right:0;}
  .stats-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>

<!-- Sidebar -->
<%- include("sidebar") %>

<div class="main">
  <div class="page-header">
    <h1>مرحباً، <%= adminName %> 👋</h1>
    <p>نظرة عامة على متجر Whisper</p>
  </div>

  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="icon">💰</div>
      <div class="value"><%= stats.revenue.toLocaleString() %></div>
      <div class="label">إجمالي الإيرادات (ر.س)</div>
    </div>
    <div class="stat-card">
      <div class="icon">📦</div>
      <div class="value"><%= stats.orders %></div>
      <div class="label">إجمالي الطلبات</div>
    </div>
    <div class="stat-card">
      <div class="icon">⏳</div>
      <div class="value"><%= stats.pendingOrders %></div>
      <div class="label">طلبات بانتظار التأكيد</div>
    </div>
    <div class="stat-card">
      <div class="icon">📷</div>
      <div class="value"><%= stats.products %></div>
      <div class="label">المنتجات</div>
    </div>
    <div class="stat-card">
      <div class="icon">🔄</div>
      <div class="value"><%= stats.activeOrders %></div>
      <div class="label">إيجارات نشطة</div>
    </div>
    <div class="stat-card">
      <div class="icon">⭐</div>
      <div class="value"><%= stats.reviews %></div>
      <div class="label">التقييمات</div>
    </div>
    <div class="stat-card">
      <div class="icon">✉️</div>
      <div class="value"><%= stats.unreadMessages %></div>
      <div class="label">رسائل غير مقروءة</div>
    </div>
    <div class="stat-card">
      <div class="icon">📊</div>
      <div class="value"><%= stats.messages %></div>
      <div class="label">إجمالي الرسائل</div>
    </div>
    <div class="stat-card">
      <div class="icon">👥</div>
      <div class="value"><%= stats.customers %></div>
      <div class="label">الأعضاء المسجلين</div>
    </div>
  </div>

  <!-- Recent Orders -->
  <div class="table-wrap">
    <div class="table-header">
      <h3>📦 آخر الطلبات</h3>
      <a href="/admin/orders" class="btn-sm btn-accent">عرض الكل</a>
    </div>
    <table>
      <thead>
        <tr>
          <th>رقم الطلب</th>
          <th>العميل</th>
          <th>المبلغ</th>
          <th>الحالة</th>
          <th>التاريخ</th>
        </tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(order => { %>
        <tr>
          <td style="font-weight:700;direction:ltr;text-align:right;"><%= order.orderId %></td>
          <td><%= order.customer.name %></td>
          <td style="font-weight:700;color:var(--accent);"><%= order.totalAmount %> ر.س</td>
          <td>
            <span class="status-badge status-<%= order.status %>">
              <%= order.status === 'pending' ? 'بانتظار التأكيد' : order.status === 'confirmed' ? 'مؤكد' : order.status === 'active' ? 'نشط' : order.status === 'returned' ? 'مُرجع' : 'ملغي' %>
            </span>
          </td>
          <td style="color:var(--dim);font-size:0.85rem;"><%= new Date(order.createdAt).toLocaleDateString('ar-SA') %></td>
        </tr>
        <% }) %>
        <% if (recentOrders.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;color:var(--dim);padding:40px;">لا توجد طلبات بعد</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

</body>
</html>
