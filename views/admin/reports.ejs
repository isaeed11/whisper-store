<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Whisper — تقارير المبيعات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=Noto+Kufi+Arabic:wght@700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link rel="stylesheet" href="/css/admin.css">
<style>
:root{--bg:#0a0a0a;--card:#111;--elevated:#1a1a1a;--accent:#c8a97e;--accent-glow:rgba(200,169,126,0.15);--text:#f0ece4;--dim:#8a8578;--muted:#5a5650;--border:rgba(200,169,126,0.12);--success:#6db56d;--danger:#c75050;--radius:14px}
*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Tajawal',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
.sidebar{width:260px;background:var(--card);border-left:1px solid var(--border);padding:24px 0;position:fixed;top:0;right:0;height:100vh;display:flex;flex-direction:column;z-index:10}.sidebar-logo{font-family:'Noto Kufi Arabic',serif;font-size:1.3rem;font-weight:900;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:0 24px 24px;border-bottom:1px solid var(--border)}.sidebar-logo span{display:block;font-size:.65rem;font-weight:400;color:var(--dim)}.sidebar-nav{flex:1;padding:16px 12px}.sidebar-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:10px;color:var(--dim);text-decoration:none;font-size:.9rem;font-weight:500;transition:.3s;margin-bottom:4px}.sidebar-nav a:hover{background:var(--elevated);color:var(--text)}.sidebar-nav a.active{background:var(--accent-glow);color:var(--accent);font-weight:700}.sidebar-nav a .icon{font-size:1.1rem;width:24px;text-align:center}.sidebar-bottom{padding:16px 24px;border-top:1px solid var(--border)}.sidebar-bottom a{color:var(--dim);text-decoration:none;font-size:.85rem}
.main{margin-right:260px;flex:1;padding:32px}.page-header{margin-bottom:32px}.page-header h1{font-family:'Noto Kufi Arabic',serif;font-size:1.6rem;font-weight:800}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:32px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px}.stat-card .val{font-family:'Noto Kufi Arabic',serif;font-size:1.8rem;font-weight:900;color:var(--accent)}.stat-card .lbl{color:var(--dim);font-size:.85rem;margin-top:4px}
.chart-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:24px}.chart-card h3{font-family:'Noto Kufi Arabic',serif;font-size:1.1rem;font-weight:700;margin-bottom:20px}
.chart-wrap{position:relative;height:300px}
.top-products{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}.top-products h3{font-family:'Noto Kufi Arabic',serif;font-size:1.1rem;font-weight:700;padding:20px 24px;border-bottom:1px solid var(--border)}
table{width:100%;border-collapse:collapse}th{text-align:right;padding:12px 24px;font-size:.8rem;color:var(--dim);font-weight:600;border-bottom:1px solid var(--border)}td{padding:12px 24px;font-size:.9rem;border-bottom:1px solid var(--border)}tr:hover td{background:var(--elevated)}
@media(max-width:768px){.sidebar{display:none}.main{margin-right:0}}
</style>
</head>
<body>
<%- include("sidebar") %>

<div class="main">
  <div class="page-header"><h1>📈 تقارير المبيعات</h1></div>

  <div class="stats-row">
    <div class="stat-card"><div class="val"><%= report.totalRevenue.toLocaleString() %> ر.س</div><div class="lbl">إجمالي الإيرادات</div></div>
    <div class="stat-card"><div class="val"><%= report.totalOrders %></div><div class="lbl">إجمالي الطلبات</div></div>
    <div class="stat-card"><div class="val"><%= report.thisMonthRevenue.toLocaleString() %> ر.س</div><div class="lbl">إيرادات هذا الشهر</div></div>
    <div class="stat-card"><div class="val"><%= report.thisMonthOrders %></div><div class="lbl">طلبات هذا الشهر</div></div>
    <div class="stat-card"><div class="val"><%= report.avgOrderValue %> ر.س</div><div class="lbl">متوسط قيمة الطلب</div></div>
    <div class="stat-card"><div class="val"><%= report.totalDiscounts %> ر.س</div><div class="lbl">إجمالي الخصومات</div></div>
  </div>

  <div class="chart-card">
    <h3>📊 الإيرادات الشهرية (آخر 12 شهر)</h3>
    <div class="chart-wrap"><canvas id="monthlyChart"></canvas></div>
  </div>

  <div class="chart-card">
    <h3>📅 الطلبات اليومية (آخر 30 يوم)</h3>
    <div class="chart-wrap"><canvas id="dailyChart"></canvas></div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
    <div class="top-products">
      <h3>🏆 الأكثر تأجيراً</h3>
      <table>
        <thead><tr><th>المعدة</th><th>عدد الطلبات</th><th>الإيرادات</th></tr></thead>
        <tbody>
          <% report.topProducts.forEach(p => { %>
          <tr><td style="font-weight:700"><%= p.name %></td><td><%= p.count %></td><td style="color:var(--accent);font-weight:700"><%= p.revenue.toLocaleString() %> ر.س</td></tr>
          <% }) %>
          <% if(!report.topProducts.length) { %><tr><td colspan="3" style="text-align:center;color:var(--dim);padding:30px">لا توجد بيانات</td></tr><% } %>
        </tbody>
      </table>
    </div>
    <div class="top-products">
      <h3>📊 حالات الطلبات</h3>
      <table>
        <thead><tr><th>الحالة</th><th>العدد</th></tr></thead>
        <tbody>
          <tr><td>بانتظار التأكيد</td><td style="font-weight:700;color:#d4a843"><%= report.statusCounts.pending %></td></tr>
          <tr><td>مؤكد</td><td style="font-weight:700;color:var(--success)"><%= report.statusCounts.confirmed %></td></tr>
          <tr><td>نشط</td><td style="font-weight:700;color:#64a0ff"><%= report.statusCounts.active %></td></tr>
          <tr><td>مُرجع</td><td style="font-weight:700;color:var(--accent)"><%= report.statusCounts.returned %></td></tr>
          <tr><td>ملغي</td><td style="font-weight:700;color:var(--danger)"><%= report.statusCounts.cancelled %></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
const chartOpts = { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } },
  scales: { x: { ticks: { color: '#8a8578', font: { family: 'Tajawal' } }, grid: { color: 'rgba(200,169,126,0.08)' } },
            y: { ticks: { color: '#8a8578', font: { family: 'Tajawal' } }, grid: { color: 'rgba(200,169,126,0.08)' } } } };

new Chart(document.getElementById('monthlyChart'), {
  type: 'bar',
  data: { labels: <%- JSON.stringify(report.monthlyLabels) %>, datasets: [{ data: <%- JSON.stringify(report.monthlyData) %>, backgroundColor: 'rgba(200,169,126,0.3)', borderColor: '#c8a97e', borderWidth: 1, borderRadius: 6 }] },
  options: chartOpts
});

new Chart(document.getElementById('dailyChart'), {
  type: 'line',
  data: { labels: <%- JSON.stringify(report.dailyLabels) %>, datasets: [{ data: <%- JSON.stringify(report.dailyData) %>, borderColor: '#c8a97e', backgroundColor: 'rgba(200,169,126,0.1)', fill: true, tension: 0.4, pointRadius: 3, pointBackgroundColor: '#c8a97e' }] },
  options: chartOpts
});
</script>
</body></html>
